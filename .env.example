# ============================================================
# Variables de entorno — Paletas INNOLATTE
# Copia este archivo a ".env.local" y rellena con tus valores
# del proyecto de Supabase (Settings -> API).
# ============================================================

# URL del proyecto Supabase (ej: https://abcd1234.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública "anon" (segura para el navegador)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave "service_role" (SECRETA — solo para el script de importación,
# NUNCA se expone al navegador). Settings -> API -> service_role.
SUPABASE_SERVICE_ROLE_KEY=
